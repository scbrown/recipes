{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "variants",
          "responsive",
          "screen",
          "layer",
          "theme",
          "utility",
          "custom-variant",
          "config",
          "reference",
          "source"
        ]
      }
    ],
    "no-descending-specificity": null,
    "custom-property-pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
    "selector-class-pattern": null
  },
  "ignoreFiles": ["dist/**", ".astro/**", "node_modules/**"]
}
