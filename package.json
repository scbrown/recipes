{
  "name": "recipes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "lint:format": "prettier --check .",
    "lint:prose": "cspell --no-progress --gitignore \"**/*.md\" \"src/content/**/*.{md,yaml,yml}\"",
    "fix": "pnpm run \"/^fix:.*/\"",
    "fix:js": "eslint . --fix",
    "fix:css": "stylelint \"src/**/*.css\" --fix",
    "fix:md": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "fix:format": "prettier --write .",
    "validate": "node scripts/validate.mjs",
    "hygiene": "knip",
    "test": "pnpm run \"/^test:.*/\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^8.1.1",
    "astro": "^6.3.3",
    "svelte": "^5.55.7",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cspell/dict-en_us": "^4.4.33",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "cspell": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,astro,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write",
      "cspell --no-progress --no-must-find-files"
    ],
    "src/content/ingredients/**/*.{yaml,yml}": [
      "node scripts/validate.mjs"
    ],
    "src/content/recipes/**/*.md": [
      "node scripts/validate.mjs"
    ]
  }
}
