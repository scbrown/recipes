{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/pages/**/*.astro",
    "src/content.config.ts",
    "astro.config.mjs",
    "vitest.config.ts",
    "tests/**/*.test.ts",
    "scripts/*.mjs"
  ],
  "project": ["src/**/*.{ts,tsx,astro,svelte,js,mjs}"],
  "ignore": ["dist/**", ".astro/**"]
}
