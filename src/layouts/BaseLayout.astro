---
import '@fontsource/intel-one-mono/400.css';
import '@fontsource/intel-one-mono/500.css';
import '@fontsource/intel-one-mono/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'Recipes';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
const navItems = [
  { href: 'recipes', label: 'Recipes', code: '01' },
  { href: 'ingredients', label: 'Ingredients', code: '02' },
  { href: 'compare', label: 'Compare', code: '03' },
  { href: 'search', label: 'Search', code: '04' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner container">
        <a href={import.meta.env.BASE_URL} class="brand">
          <span class="brand-mark">▮▮</span>
          <span class="brand-text">Recipes / Stainless Kitchen</span>
        </a>
        <nav>
          {
            navItems.map((item) => (
              <a href={`${import.meta.env.BASE_URL}/${item.href}`}>
                <span class="nav-code">{item.code}</span>
                <span class="nav-label">{item.label}</span>
              </a>
            ))
          }
        </nav>
      </div>
      <div class="header-rail container">
        <span>SYS / STATIC BUILD</span>
        <span class="header-rail-dot">●</span>
        <span>SCHEMA · ZOD</span>
        <span class="header-rail-dot">●</span>
        <span>UNITS · METRIC + US</span>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-row">
          <span class="footer-tag">CC-BY-4.0</span>
          <span class="footer-sep">|</span>
          <span>
            Recipes by their authors. Site content licensed under
            <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.
          </span>
        </div>
      </div>
    </footer>

    <style>
      .container {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .site-header {
        background: linear-gradient(
          180deg,
          var(--color-surface-raised) 0%,
          var(--color-surface) 100%
        );
        border-bottom: 1px solid var(--color-rule);
        margin-bottom: 2rem;
        position: relative;
      }
      .site-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          90deg,
          transparent 0 2px,
          rgb(255 255 255 / 1.5%) 2px 3px
        );
        pointer-events: none;
      }
      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        padding-block: 1.1rem;
        position: relative;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-steel-100);
        border-bottom: 0;
        padding-bottom: 0;
      }
      .brand:hover {
        background: transparent;
        color: var(--color-accent);
      }
      .brand-mark {
        color: var(--color-accent);
        font-size: 0.8rem;
        letter-spacing: -0.1em;
      }
      nav {
        display: flex;
        gap: 0;
      }
      nav a {
        display: inline-flex;
        align-items: baseline;
        gap: 0.45rem;
        color: var(--color-steel-200);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        font-weight: 500;
        padding: 0.5rem 0.9rem;
        border-bottom: 0;
        border-left: 1px solid var(--color-rule);
      }
      nav a:first-child {
        border-left: 1px solid var(--color-rule);
      }
      nav a:last-child {
        border-right: 1px solid var(--color-rule);
      }
      nav a:hover {
        background: var(--color-surface-raised);
        color: var(--color-accent);
      }
      .nav-code {
        color: var(--color-steel-500);
        font-size: 0.7rem;
      }
      .header-rail {
        display: flex;
        gap: 0.8rem;
        align-items: center;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-steel-500);
        border-top: 1px solid var(--color-rule);
        padding-block: 0.55rem;
        position: relative;
      }
      .header-rail-dot {
        color: var(--color-accent);
        font-size: 0.5rem;
        line-height: 1;
      }
      .site-footer {
        margin-top: 6rem;
        padding-block: 1.6rem;
        border-top: 1px solid var(--color-rule);
        background: var(--color-surface);
        font-size: 0.78rem;
        color: var(--color-steel-500);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .footer-row {
        display: flex;
        gap: 0.6rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .footer-tag {
        background: var(--color-surface-raised);
        border: 1px solid var(--color-rule);
        padding: 0.15rem 0.45rem;
        color: var(--color-steel-200);
        font-weight: 600;
      }
      .footer-sep {
        color: var(--color-steel-700);
      }
      .site-footer a {
        color: var(--color-steel-300);
      }
      .site-footer a:hover {
        color: var(--color-accent);
      }

      @media (max-width: 640px) {
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.8rem;
        }
        nav {
          flex-wrap: wrap;
        }
        .header-rail {
          display: none;
        }
      }
    </style>
  </body>
</html>
