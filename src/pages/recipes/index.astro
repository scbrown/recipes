---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const recipes = (await getCollection('recipes', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="All recipes">
  <h1>All recipes</h1>
  <ul class="recipe-list ui">
    {
      recipes.map((recipe) => (
        <li>
          <a href={`${base}/recipes/${recipe.id}`}>{recipe.data.title}</a>
          {recipe.data.summary && <p class="muted">{recipe.data.summary}</p>}
        </li>
      ))
    }
  </ul>

  <style>
    .recipe-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .recipe-list li {
      padding: 1rem 0;
      border-bottom: 1px solid var(--color-rule);
    }
    .recipe-list a {
      font-family: var(--font-body);
      font-size: 1.1rem;
      font-weight: 600;
    }
    .muted {
      margin: 0.25rem 0 0;
      font-size: 0.9rem;
    }
  </style>
</BaseLayout>
