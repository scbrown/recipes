---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeInteractive from '../../components/recipe/RecipeInteractive.svelte';
import { buildRecipePayload } from '../../lib/build-payload.ts';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes', ({ data }) => !data.draft);
  return recipes.map((recipe) => ({ params: { id: recipe.id }, props: { recipe } }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const payload = await buildRecipePayload(recipe);
---

<BaseLayout title={recipe.data.title} description={recipe.data.summary}>
  <article>
    <header class="recipe-header">
      <ul class="tags ui">
        {recipe.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
      <h1>{recipe.data.title}</h1>
      {recipe.data.summary && <p class="lede">{recipe.data.summary}</p>}
      {
        recipe.data.yields && (
          <p class="ui muted yields">
            <span>Yields:</span> {recipe.data.yields}
          </p>
        )
      }
    </header>

    <RecipeInteractive payload={payload} client:load />

    <section class="instructions prose">
      <Content />
    </section>
  </article>

  <style>
    .recipe-header {
      margin-bottom: 2.5rem;
    }
    .tags {
      list-style: none;
      padding: 0;
      margin: 0 0 0.75rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .tags li {
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.2rem 0.55rem;
      background: var(--color-bg);
      color: var(--color-steel-300);
      border: 1px solid var(--color-rule);
      border-radius: 0;
    }
    .lede {
      font-size: 1.05rem;
      color: var(--color-steel-300);
      margin-block: 0.8rem 0;
      max-width: var(--measure-base);
      line-height: 1.5;
    }
    .yields {
      margin-top: 0.8rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .yields span {
      font-weight: 600;
      color: var(--color-accent);
    }
    .instructions {
      margin-top: 1rem;
    }
  </style>
</BaseLayout>
