---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const ingredients = (await getCollection('ingredients')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ingredient library">
  <h1>Ingredient library</h1>
  <p class="muted">
    {ingredients.length} ingredients. Click for nutrition details and recipes that use each.
  </p>
  <ul class="ingredient-list ui">
    {
      ingredients.map((ing) => (
        <li>
          <a href={`${base}/ingredients/${ing.id}`}>{ing.data.name}</a>
          <span class="roles muted">{ing.data.roles.join(', ')}</span>
        </li>
      ))
    }
  </ul>

  <style>
    .ingredient-list {
      list-style: none;
      padding: 0;
      margin: 2rem 0 0;
      display: grid;
      gap: 0.25rem;
    }
    .ingredient-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--color-rule);
    }
    .roles {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  </style>
</BaseLayout>
