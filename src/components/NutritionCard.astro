---
import type { Nutrients } from '../lib/nutrition/types.ts';

interface Props {
  total: Nutrients;
  perServing: Nutrients | null;
  serving?: string;
}

const { total, perServing, serving } = Astro.props;
const display = perServing ?? total;
const heading = perServing
  ? `Per serving (${serving ?? 'estimated'})`
  : 'Total (no serving size set)';

function fmt(n: number | undefined): string {
  if (n === undefined) return '—';
  return n.toFixed(n < 10 ? 1 : 0);
}
---

<aside class="nutrition-card ui">
  <h3>{heading}</h3>
  <dl>
    <div><dt>Calories</dt><dd>{fmt(display.calories)}</dd></div>
    <div><dt>Protein</dt><dd>{fmt(display.protein)} g</dd></div>
    <div><dt>Carbs</dt><dd>{fmt(display.carbohydrate)} g</dd></div>
    <div><dt>Net carbs</dt><dd>{fmt(display.net_carbs)} g</dd></div>
    <div><dt>Fat</dt><dd>{fmt(display.fat)} g</dd></div>
    <div><dt>Fiber</dt><dd>{fmt(display.fiber)} g</dd></div>
    <div><dt>Sodium</dt><dd>{fmt(display.sodium_mg)} mg</dd></div>
  </dl>
  <p class="footnote muted">
    Computed at build time from the ingredient library. Brand-dependent and approximate — see the
    methodology page for caveats.
  </p>
</aside>

<style>
  .nutrition-card {
    background: var(--color-card);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-base);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .nutrition-card h3 {
    margin-block: 0 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    font-family: var(--font-ui);
    font-weight: 600;
  }
  dl {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem 1rem;
  }
  dl > div {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-rule);
    padding: 0.35rem 0;
  }
  dl > div:last-of-type {
    border-bottom: 0;
  }
  dt {
    font-weight: 400;
    color: var(--color-fg);
  }
  dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  .footnote {
    font-size: 0.75rem;
    margin-block: 1rem 0;
    line-height: 1.4;
  }
</style>
